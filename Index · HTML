<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CipherChat — Real-Time QR Secure Comm</title>

<!-- Socket.IO client (must match server version) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.5/socket.io.min.js"></script>
<!-- QR scanner -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html5-qrcode/2.3.8/html5-qrcode.min.js"></script>
<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
/* ════════════════ RESET & THEME ════════════════ */
:root {
  --bg0:#040609; --bg1:#080d14; --bg2:#0d1520; --bg3:#111d2c; --panel:#0a1220;
  --border:rgba(0,200,120,0.12); --border2:rgba(0,200,120,0.28);
  --green:#00e090; --gdim:#00804a; --gglow:rgba(0,224,144,0.18);
  --cyan:#00c8ff; --cdim:#006888;
  --red:#ff3c5a; --rdim:#7a0020; --rglow:rgba(255,60,90,0.22);
  --amber:#ffaa00; --adim:#7a4f00;
  --text:#c8e6d0; --tdim:#4a7a5a;
  --mono:'Share Tech Mono',monospace; --sans:'Exo 2',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{background:var(--bg0);color:var(--text);font-family:var(--sans);font-size:13px;display:flex;flex-direction:column}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.03) 2px,rgba(0,0,0,0.03) 4px);pointer-events:none;z-index:9999}

/* ════════════════ TOPBAR ════════════════ */
#topbar{background:var(--bg1);border-bottom:1px solid var(--border2);padding:8px 20px;display:flex;align-items:center;gap:16px;flex-shrink:0;position:relative}
#topbar::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--green),transparent);opacity:.4}
.logo{font-family:var(--mono);font-size:18px;color:var(--green);letter-spacing:3px;text-shadow:0 0 20px var(--green)}
.logo span{color:var(--cyan)}
.topbar-stats{margin-left:auto;display:flex;gap:20px;align-items:center}
.ts{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px}
.ts-l{color:var(--tdim)} .ts-v{color:var(--green)}
.dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:pulse 1.4s ease-in-out infinite}
.dot.r{background:var(--red);box-shadow:0 0 8px var(--red)}
.dot.a{background:var(--amber);box-shadow:0 0 8px var(--amber)}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.7)}}

/* ════════════════ LAYOUT ════════════════ */
#app{display:flex;flex:1;overflow:hidden}

/* ════════════════ SIDEBAR ════════════════ */
#sidebar{width:244px;min-width:244px;background:var(--panel);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;overflow-x:hidden}
.sb-sec{padding:13px 15px;border-bottom:1px solid var(--border)}
.sb-hd{font-family:var(--mono);font-size:9px;letter-spacing:3px;color:var(--tdim);text-transform:uppercase;margin-bottom:9px}
.sb-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px}
.sb-k{font-size:11px;color:var(--tdim);font-family:var(--mono)}
.sb-v{font-family:var(--mono);font-size:11px;color:var(--green)}
.sb-v.r{color:var(--red)} .sb-v.a{color:var(--amber)} .sb-v.c{color:var(--cyan)}

/* QR display in sidebar */
.qr-wrap{background:var(--bg3);border:1px solid var(--border2);border-radius:6px;padding:10px;margin-top:6px;display:flex;flex-direction:column;align-items:center;gap:6px}
.qr-wrap svg{width:120px;height:120px;border-radius:3px}
.qr-label{font-family:var(--mono);font-size:9px;color:var(--tdim);letter-spacing:2px;text-align:center}
.qr-url{font-family:var(--mono);font-size:8px;color:var(--cyan);word-break:break-all;text-align:center;max-width:100%}

/* bars */
.bar-bg{height:6px;background:var(--bg3);border-radius:3px;overflow:hidden;margin-top:4px}
.bar-fill{height:100%;border-radius:3px;transition:width .8s ease,background .8s ease}
.lbar-bg{height:4px;background:var(--bg3);border-radius:2px;overflow:hidden;margin-top:5px}
.lbar-fill{height:100%;border-radius:2px;transition:width .4s ease}

/* token */
.tok-disp{font-family:var(--mono);font-size:9px;color:var(--cyan);background:var(--bg3);border:1px solid var(--cdim);border-radius:4px;padding:5px 7px;word-break:break-all;margin-top:5px;letter-spacing:1px}
.tok-stat{margin-top:5px;font-family:var(--mono);font-size:10px;padding:3px 8px;border-radius:3px;display:inline-block}
.tok-stat.safe{color:var(--green);background:rgba(0,224,144,.08);border:1px solid var(--gdim)}
.tok-stat.comp{color:var(--red);background:rgba(255,60,90,.12);border:1px solid var(--rdim);animation:flash .4s ease infinite}
@keyframes flash{0%,100%{border-color:var(--red)}50%{border-color:transparent}}

/* geo */
.geo-flag{font-size:17px;line-height:1}
.geo-city{color:var(--red);font-family:var(--mono);font-size:10px}
.geo-coord{color:var(--tdim);font-family:var(--mono);font-size:9px;margin-top:1px}

/* sniffer badge */
.sniff{display:inline-flex;align-items:center;gap:5px;font-family:var(--mono);font-size:10px;padding:3px 8px;border-radius:3px;background:rgba(255,60,90,.1);border:1px solid var(--rdim);color:var(--red)}
.sniff.idle{background:rgba(0,224,144,.07);border-color:var(--gdim);color:var(--green)}

/* stat grid */
.sgrid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:6px}
.si{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:7px;text-align:center}
.siv{font-family:var(--mono);font-size:17px;font-weight:700;line-height:1}
.siv.g{color:var(--green)} .siv.r{color:var(--red)} .siv.a{color:var(--amber)} .siv.c{color:var(--cyan)}
.sil{font-size:9px;color:var(--tdim);margin-top:2px;font-family:var(--mono);letter-spacing:1px}

/* buttons */
.scan-btn{margin:12px 14px;padding:9px;font-family:var(--mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;background:transparent;color:var(--green);border:1px solid var(--gdim);border-radius:4px;cursor:pointer;width:calc(100% - 28px);transition:all .2s}
.scan-btn:hover{background:var(--gglow);border-color:var(--green);box-shadow:0 0 16px var(--gglow)}

/* ws badge */
.ws-badge{display:inline-flex;align-items:center;gap:5px;font-family:var(--mono);font-size:9px;padding:2px 7px;border-radius:3px;background:rgba(0,224,144,.07);border:1px solid var(--gdim);color:var(--green);margin-top:6px}
.ws-badge.off{color:var(--red);border-color:var(--rdim);background:rgba(255,60,90,.07)}

/* ════════════════ MAIN ════════════════ */
#main{flex:1;display:flex;flex-direction:column;overflow:hidden;background:var(--bg1)}
#mbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:5px 16px;display:flex;gap:22px;align-items:center;flex-shrink:0;font-family:var(--mono);font-size:10px}
.mi{display:flex;align-items:center;gap:5px}
.ml{color:var(--tdim)} .mv{color:var(--green);font-weight:600}
.mv.r{color:var(--red)} .mv.a{color:var(--amber)} .mv.c{color:var(--cyan)}
#main.atk{animation:atkflash .5s ease}
@keyframes atkflash{0%,100%{background:var(--bg1)}50%{background:rgba(255,60,90,.06)}}

/* chat feed */
#feed{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:7px}
#feed::-webkit-scrollbar{width:3px}
#feed::-webkit-scrollbar-thumb{background:var(--gdim);border-radius:2px}

/* messages */
.msg{display:flex;gap:9px;animation:fadein .3s ease;max-width:86%}
.msg.own{flex-direction:row-reverse;align-self:flex-end}
.ava{width:29px;height:29px;border-radius:50%;background:var(--bg3);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:9px;color:var(--green);flex-shrink:0}
.msg.own .ava{color:var(--cyan);border-color:var(--cdim)}
.mc{flex:1}
.mm{display:flex;gap:7px;align-items:baseline;margin-bottom:3px}
.msg.own .mm{flex-direction:row-reverse}
.mu{font-family:var(--mono);font-size:11px;color:var(--green);font-weight:600}
.msg.own .mu{color:var(--cyan)}
.mt{font-family:var(--mono);font-size:9px;color:var(--tdim)}
.mb{background:var(--bg3);border:1px solid var(--border);border-radius:2px 8px 8px 8px;padding:7px 11px;font-size:13px;line-height:1.5;color:var(--text)}
.msg.own .mb{border-radius:8px 2px 8px 8px;border-color:var(--cdim);background:rgba(0,200,255,.05)}
.msg.icp .mb{border-color:var(--red);background:rgba(255,60,90,.08);animation:icppulse 2s ease infinite}
@keyframes icppulse{0%,100%{box-shadow:0 0 0 0 transparent}50%{box-shadow:0 0 10px rgba(255,60,90,.3)}}
.ibadge{display:inline-flex;align-items:center;gap:4px;font-family:var(--mono);font-size:9px;color:var(--red);background:rgba(255,60,90,.15);border:1px solid var(--rdim);border-radius:3px;padding:1px 5px;margin-left:5px;vertical-align:middle}

/* system messages */
.sys{text-align:center;font-family:var(--mono);font-size:10px;color:var(--tdim);padding:4px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:20px;align-self:center;letter-spacing:1px;animation:fadein .3s ease}
.sys.al{color:var(--amber);border-color:var(--adim);background:rgba(255,170,0,.07)}
.sys.dg{color:var(--red);border-color:var(--rdim);background:rgba(255,60,90,.07)}
@keyframes fadein{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* input area */
#inarea{padding:11px 15px;border-top:1px solid var(--border);background:var(--bg2);display:flex;gap:9px;align-items:center;flex-shrink:0}
#msginput{flex:1;background:var(--bg3);border:1px solid var(--border2);border-radius:4px;padding:9px 13px;font-family:var(--mono);font-size:12px;color:var(--text);outline:none;transition:border-color .2s}
#msginput:focus{border-color:var(--green)}
#msginput::placeholder{color:var(--tdim)}
#sendbtn{background:var(--gdim);border:1px solid var(--green);color:var(--green);font-family:var(--mono);font-size:11px;padding:9px 16px;border-radius:4px;cursor:pointer;letter-spacing:2px;text-transform:uppercase;transition:all .2s}
#sendbtn:hover{background:var(--green);color:var(--bg0);box-shadow:0 0 20px var(--gglow)}
.rindicator{font-family:var(--mono);font-size:10px;color:var(--tdim);background:var(--bg3);border:1px solid var(--border);border-radius:3px;padding:4px 7px;white-space:nowrap}

/* ════════════════ QR SCAN MODAL ════════════════ */
#modal{position:fixed;inset:0;background:rgba(4,6,9,.97);display:flex;align-items:center;justify-content:center;z-index:1000;flex-direction:column;gap:20px}
.mbox{background:var(--bg2);border:1px solid var(--border2);border-radius:9px;padding:28px;width:370px;text-align:center;box-shadow:0 0 60px rgba(0,224,144,.08)}
.mtitle{font-family:var(--mono);font-size:14px;letter-spacing:4px;color:var(--green);text-transform:uppercase;margin-bottom:5px}
.msub{font-size:11px;color:var(--tdim);font-family:var(--mono);margin-bottom:20px}

/* scanner container */
#qr-reader{border-radius:6px;overflow:hidden;border:1px solid var(--border2);background:#000;min-height:220px}
#qr-reader video{border-radius:0!important}

/* scan mode toggle */
.mode-tabs{display:flex;gap:0;margin-bottom:14px;border:1px solid var(--border2);border-radius:5px;overflow:hidden}
.mode-tab{flex:1;padding:7px;font-family:var(--mono);font-size:10px;letter-spacing:1px;border:none;background:transparent;color:var(--tdim);cursor:pointer;transition:all .2s;text-transform:uppercase}
.mode-tab.active{background:var(--gglow);color:var(--green)}

/* manual entry */
.manual-row{display:flex;gap:7px}
.manual-row input{flex:1;background:var(--bg3);border:1px solid var(--border2);border-radius:4px;padding:8px 11px;font-family:var(--mono);font-size:11px;color:var(--text);outline:none}
.manual-row input:focus{border-color:var(--green)}
.manual-row input::placeholder{color:var(--tdim)}
.manual-row button{background:var(--bg3);border:1px solid var(--gdim);color:var(--green);font-family:var(--mono);font-size:10px;padding:8px 11px;border-radius:4px;cursor:pointer;letter-spacing:1px;transition:all .2s}
.manual-row button:hover{background:var(--gglow)}
.demo-lbl{font-family:var(--mono);font-size:9px;color:var(--tdim);letter-spacing:2px;margin:12px 0 7px;text-align:left}
.pills{display:flex;gap:8px;flex-wrap:wrap}
.pill{font-family:var(--mono);font-size:10px;color:var(--cyan);background:rgba(0,200,255,.07);border:1px solid var(--cdim);border-radius:3px;padding:4px 10px;cursor:pointer;transition:all .2s}
.pill:hover{background:rgba(0,200,255,.15);border-color:var(--cyan)}
.sep{font-family:var(--mono);font-size:9px;color:var(--tdim);letter-spacing:2px;margin:10px 0}

/* ════════════════ THREAT OVERLAY ════════════════ */
#threat{position:fixed;top:58px;right:18px;background:rgba(255,60,90,.12);border:1px solid var(--red);border-radius:6px;padding:9px 15px;font-family:var(--mono);font-size:11px;color:var(--red);opacity:0;transform:translateX(20px);transition:all .3s ease;pointer-events:none;z-index:500;max-width:220px}
#threat.vis{opacity:1;transform:translateX(0)}

/* ════════════════ CONNECTING SCREEN ════════════════ */
#connecting{position:fixed;inset:0;background:var(--bg0);display:none;align-items:center;justify-content:center;flex-direction:column;gap:16px;z-index:900;font-family:var(--mono)}
#connecting.show{display:flex}
.conn-logo{font-size:24px;color:var(--green);letter-spacing:4px;animation:connpulse 1s ease infinite}
@keyframes connpulse{0%,100%{opacity:1}50%{opacity:.4}}
.conn-msg{font-size:11px;color:var(--tdim);letter-spacing:2px}

::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-thumb{background:var(--gdim);border-radius:2px}
</style>
</head>
<body>

<!-- CONNECTING OVERLAY (shown when navigating directly to /join/ROOM-XXX) -->
<div id="connecting">
  <div class="conn-logo">◈ CIPHERCHAT</div>
  <div class="conn-msg" id="conn-msg">CONNECTING TO ROOM...</div>
</div>

<!-- THREAT OVERLAY -->
<div id="threat">⚠ THREAT DETECTED</div>

<!-- QR SCAN MODAL -->
<div id="modal">
  <div class="mbox">
    <div class="mtitle">◈ CIPHERCHAT</div>
    <div class="msub">SCAN QR CODE OR ENTER ROOM ID</div>

    <div class="mode-tabs">
      <button class="mode-tab active" id="tab-scan" onclick="setMode('scan')">⬡ CAMERA SCAN</button>
      <button class="mode-tab" id="tab-manual" onclick="setMode('manual')">⌨ MANUAL</button>
    </div>

    <!-- Camera scanner -->
    <div id="scan-panel">
      <div id="qr-reader"></div>
      <div class="sep">── OR CLICK A DEMO ROOM ──</div>
    </div>

    <!-- Manual entry -->
    <div id="manual-panel" style="display:none">
      <div class="manual-row">
        <input type="text" id="room-input" placeholder="ROOM-XXXXXXXX" maxlength="20" onkeydown="if(event.key==='Enter')joinManual()">
        <button onclick="joinManual()">JOIN</button>
      </div>
      <div class="sep">── OR CLICK A DEMO ROOM ──</div>
    </div>

    <div class="demo-lbl">DEMO ROOMS</div>
    <div class="pills">
      <span class="pill" onclick="joinRoom('ROOM-ALPHA7X')">ALPHA-7X</span>
      <span class="pill" onclick="joinRoom('ROOM-BETA3K')">BETA-3K</span>
      <span class="pill" onclick="joinRoom('ROOM-DELTA9Z')">DELTA-9Z</span>
      <span class="pill" onclick="joinRoom('ROOM-OMEGA1F')">OMEGA-1F</span>
    </div>
  </div>
</div>

<!-- TOPBAR -->
<div id="topbar">
  <div class="logo">CIPHER<span>CHAT</span></div>
  <div class="topbar-stats">
    <div class="ts"><div class="dot" id="sdot"></div><span class="ts-l">STATUS</span><span class="ts-v" id="stxt">PROTECTED</span></div>
    <div class="ts"><span class="ts-l">RPS</span><span class="ts-v" id="rps">0</span></div>
    <div class="ts"><span class="ts-l">LOAD</span><span class="ts-v" id="load">0%</span></div>
    <div class="ts"><span class="ts-l">TIME</span><span class="ts-v" id="clk">00:00:00</span></div>
  </div>
</div>

<!-- APP -->
<div id="app">

  <!-- SIDEBAR -->
  <div id="sidebar">

    <!-- Room + QR code -->
    <div class="sb-sec">
      <div class="sb-hd">◈ ROOM INFO</div>
      <div class="sb-row"><span class="sb-k">ROOM ID</span><span class="sb-v c" id="sb-room">---</span></div>
      <div class="sb-row"><span class="sb-k">USER</span><span class="sb-v" id="sb-user">---</span></div>
      <div class="sb-row"><span class="sb-k">ONLINE</span><span class="sb-v" id="sb-online">1</span></div>
      <!-- Live QR code for this room -->
      <div class="qr-wrap" id="qr-wrap" style="display:none">
        <div class="qr-label">◈ ROOM QR CODE</div>
        <div id="qr-svg-container"></div>
        <div class="qr-url" id="qr-url"></div>
      </div>
      <!-- WebSocket status -->
      <div class="ws-badge off" id="ws-badge"><span>●</span><span id="ws-txt">DISCONNECTED</span></div>
    </div>

    <!-- Sniffer -->
    <div class="sb-sec">
      <div class="sb-hd">◈ SNIFFER ENGINE</div>
      <div class="sniff idle" id="sniff-badge"><span>●</span><span id="sniff-txt">IDLE</span></div>
      <div class="sgrid">
        <div class="si"><div class="siv g" id="s-total">0</div><div class="sil">TOTAL MSG</div></div>
        <div class="si"><div class="siv r" id="s-icp">0</div><div class="sil">INTERCEPTED</div></div>
        <div class="si"><div class="siv a" id="s-exp">0%</div><div class="sil">EXPOSURE</div></div>
        <div class="si"><div class="siv c" id="s-pkt">0</div><div class="sil">PACKETS</div></div>
      </div>
    </div>

    <!-- Security score -->
    <div class="sb-sec">
      <div class="sb-hd">◈ SECURITY SCORE</div>
      <div class="sb-row"><span class="sb-k">SCORE</span><span class="sb-v" id="score-v">100%</span></div>
      <div class="bar-bg"><div class="bar-fill" id="score-bar" style="width:100%;background:var(--green)"></div></div>
    </div>

    <!-- Server metrics -->
    <div class="sb-sec">
      <div class="sb-hd">◈ SERVER METRICS</div>
      <div class="sb-row"><span class="sb-k">CPU LOAD</span><span class="sb-v" id="cpu-v">12%</span></div>
      <div class="lbar-bg"><div class="lbar-fill" id="cpu-bar" style="width:12%;background:var(--cyan)"></div></div>
      <div class="sb-row" style="margin-top:8px"><span class="sb-k">DDOS</span><span class="sb-v" id="ddos-v">CLEAR</span></div>
      <div class="sb-row"><span class="sb-k">ATTACKS</span><span class="sb-v r" id="atk-v">0</span></div>
    </div>

    <!-- Session token -->
    <div class="sb-sec">
      <div class="sb-hd">◈ SESSION TOKEN</div>
      <div class="tok-disp" id="tok-disp">●●●●●●●●●●●●</div>
      <div class="tok-stat safe" id="tok-stat">● SECURE</div>
    </div>

    <!-- Geo -->
    <div class="sb-sec">
      <div class="sb-hd">◈ ATTACKER GEO</div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:4px">
        <div class="geo-flag" id="geo-flag">🌐</div>
        <div><div class="geo-city" id="geo-city">SCANNING...</div><div class="geo-coord" id="geo-coord">---</div></div>
      </div>
    </div>

    <button class="scan-btn" onclick="openModal()">⬡ SCAN NEW QR</button>
  </div>

  <!-- MAIN CHAT -->
  <div id="main">
    <div id="mbar">
      <div class="mi"><span class="ml">PACKETS/S:</span><span class="mv" id="m-pps">0</span></div>
      <div class="mi"><span class="ml">BLOCKED:</span><span class="mv r" id="m-blk">0</span></div>
      <div class="mi"><span class="ml">LATENCY:</span><span class="mv c" id="m-lat">12ms</span></div>
      <div class="mi"><span class="ml">CIPHER:</span><span class="mv">AES-256-GCM</span></div>
      <div class="mi"><span class="ml">PROTO:</span><span class="mv c">WSS/TLS1.3</span></div>
      <div class="mi" style="margin-left:auto"><span class="ml">SNIFFER:</span><span class="mv r" id="m-sniff">SCANNING</span></div>
    </div>
    <div id="feed"></div>
    <div id="inarea">
      <span class="rindicator" id="room-ind">ROOM: ---</span>
      <input type="text" id="msginput" placeholder="SEND ENCRYPTED MESSAGE..." maxlength="200">
      <button id="sendbtn" onclick="sendMsg()">SEND ↑</button>
    </div>
  </div>

</div><!-- #app -->

<script>
/* ═══════════════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════════════ */
let socket      = null;
let sessionId   = null;
let currentRoom = null;
let username    = null;
let appActive   = false;
let blkCount    = 0;
let sniffActive = false;
let html5QrCode = null;
let scanMode    = 'scan';   // 'scan' | 'manual'
let sessionCheckTimer = null;

/* ═══════════════════════════════════════════════════════
   DEEP-LINK: /join/<ROOM-ID>  auto-join on page load
═══════════════════════════════════════════════════════ */
window.addEventListener('load', () => {
  const path = window.location.pathname;
  const m = path.match(/^\/join\/(ROOM-[A-Z0-9_-]+)$/i);
  if (m) {
    document.getElementById('connecting').classList.add('show');
    document.getElementById('modal').style.display = 'none';
    setTimeout(() => joinRoom(m[1].toUpperCase()), 600);
  } else {
    setTimeout(initScanner, 400);
  }
  setInterval(updateClock, 1000);
  updateClock();
});

/* ═══════════════════════════════════════════════════════
   MODAL / SCANNER
═══════════════════════════════════════════════════════ */
function setMode(mode) {
  scanMode = mode;
  document.getElementById('tab-scan').classList.toggle('active', mode === 'scan');
  document.getElementById('tab-manual').classList.toggle('active', mode === 'manual');
  document.getElementById('scan-panel').style.display   = mode === 'scan'   ? '' : 'none';
  document.getElementById('manual-panel').style.display = mode === 'manual' ? '' : 'none';
  if (mode === 'scan') initScanner(); else stopScanner();
}

function initScanner() {
  if (html5QrCode) return; // already running
  try {
    html5QrCode = new Html5Qrcode('qr-reader');
    html5QrCode.start(
      { facingMode: 'environment' },
      { fps: 10, qrbox: { width: 200, height: 200 } },
      (decoded) => {
        // Accept a direct room URL or a bare ROOM-XXX string
        let rid = decoded;
        const urlMatch = decoded.match(/\/join\/(ROOM-[A-Z0-9_-]+)/i);
        if (urlMatch) rid = urlMatch[1].toUpperCase();
        else if (!rid.startsWith('ROOM-')) rid = 'ROOM-' + rid.slice(0,8).toUpperCase();
        joinRoom(rid);
      },
      () => {}
    ).catch(() => {});
  } catch(e) {}
}

function stopScanner() {
  if (!html5QrCode) return;
  html5QrCode.stop().catch(() => {});
  html5QrCode = null;
}

function openModal() {
  document.getElementById('modal').style.display = 'flex';
  document.getElementById('room-input').value = '';
  if (scanMode === 'scan') setTimeout(initScanner, 300);
}

function joinManual() {
  const v = document.getElementById('room-input').value.trim().toUpperCase();
  if (!v) return;
  joinRoom(v.startsWith('ROOM-') ? v : 'ROOM-' + v);
}

/* ═══════════════════════════════════════════════════════
   JOIN ROOM  — calls backend, then connects WebSocket
═══════════════════════════════════════════════════════ */
async function joinRoom(roomId) {
  stopScanner();
  document.getElementById('conn-msg').textContent = `JOINING ${roomId}...`;
  document.getElementById('connecting').classList.add('show');
  document.getElementById('modal').style.display = 'none';

  try {
    const res  = await fetch('/api/join', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ room_id: roomId })
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error);

    currentRoom = data.room_id;
    sessionId   = data.session_id;
    username    = data.username;

    // Update sidebar static fields
    document.getElementById('sb-room').textContent  = currentRoom;
    document.getElementById('sb-user').textContent  = username;
    document.getElementById('room-ind').textContent = 'ROOM: ' + currentRoom;
    document.getElementById('tok-disp').textContent = data.masked_token;

    // Show QR code for this room in sidebar
    if (data.qr_svg) {
      document.getElementById('qr-svg-container').innerHTML = data.qr_svg;
      document.getElementById('qr-url').textContent = data.join_url || '';
      document.getElementById('qr-wrap').style.display = 'flex';
    }

    // Update browser URL without reloading
    window.history.replaceState({}, '', `/join/${currentRoom}`);

    // Connect WebSocket
    connectWS();
  } catch(e) {
    document.getElementById('conn-msg').textContent = 'ERROR: ' + (e.message || 'server unreachable');
    setTimeout(() => {
      document.getElementById('connecting').classList.remove('show');
      openModal();
    }, 2500);
  }
}

/* ═══════════════════════════════════════════════════════
   WEBSOCKET  — Socket.IO
═══════════════════════════════════════════════════════ */
function connectWS() {
  if (socket) { socket.disconnect(); socket = null; }

  socket = io({ transports: ['websocket', 'polling'] });

  socket.on('connect', () => {
    setWsBadge(true);
    // Tell server which room + session we are
    socket.emit('join_room', { room_id: currentRoom, session_id: sessionId });
  });

  socket.on('disconnect', () => setWsBadge(false));

  socket.on('room_joined', (d) => {
    document.getElementById('connecting').classList.remove('show');
    appActive = true;

    // Render history
    (d.history || []).forEach(m => renderMsg(m));
    document.getElementById('sb-online').textContent = d.online || 1;

    addSys(`${username} joined room ${currentRoom} via QR`, 'normal');
    addSys('WebSocket channel open — AES-256-GCM active', 'normal');

    startSessionChecks();
    setInterval(snifferPulse, 2500);
  });

  socket.on('new_message', (msg) => {
    renderMsg(msg);
    if (msg.intercepted && msg.username !== username) {
      sniffActive = true;
      setSniff(true);
      showThreat('PACKET INTERCEPTED');
      addSys('Sniffer flagged incoming message', 'alert');
      setTimeout(() => { sniffActive = false; setSniff(false); }, 2500);
    }
  });

  socket.on('metrics', applyMetrics);
  socket.on('geo_update', updateGeo);
  socket.on('session_attack', (d) => {
    setTokStat(true);
    showThreat('SESSION HIJACK ATTEMPT');
    addSys(d.message || 'Session attack detected', 'danger');
    setTimeout(() => setTokStat(false), 4500);
  });
  socket.on('user_joined', (d) => {
    document.getElementById('sb-online').textContent = d.online;
    addSys(`New user connected — ${d.online} online`, 'normal');
  });
  socket.on('user_left', (d) => {
    document.getElementById('sb-online').textContent = d.online;
  });
  socket.on('error', (d) => {
    addSys(d.message || 'Socket error', 'danger');
    document.getElementById('connecting').classList.remove('show');
    openModal();
  });
}

function setWsBadge(connected) {
  const b = document.getElementById('ws-badge');
  const t = document.getElementById('ws-txt');
  b.className = 'ws-badge' + (connected ? '' : ' off');
  t.textContent = connected ? 'LIVE' : 'DISCONNECTED';
}

/* ═══════════════════════════════════════════════════════
   SEND MESSAGE  — via WebSocket
═══════════════════════════════════════════════════════ */
function sendMsg() {
  const inp = document.getElementById('msginput');
  const txt = inp.value.trim();
  if (!txt || !appActive || !socket) return;
  inp.value = '';
  // Emit via WebSocket — server will broadcast back to everyone
  socket.emit('send_message', { session_id: sessionId, room_id: currentRoom, content: txt });
}
document.getElementById('msginput').addEventListener('keydown', e => { if (e.key === 'Enter') sendMsg(); });

/* ═══════════════════════════════════════════════════════
   RENDER HELPERS
═══════════════════════════════════════════════════════ */
function renderMsg(msg) {
  const feed   = document.getElementById('feed');
  const isOwn  = msg.username === username && !msg.is_bot;
  const initls = msg.username.slice(0,2).toUpperCase();
  const ts     = new Date(msg.timestamp);
  const tStr   = [ts.getHours(),ts.getMinutes(),ts.getSeconds()].map(v=>String(v).padStart(2,'0')).join(':');

  const div = document.createElement('div');
  div.className = 'msg' + (isOwn ? ' own' : '') + (msg.intercepted ? ' icp' : '');
  div.innerHTML = `
    <div class="ava">${initls}</div>
    <div class="mc">
      <div class="mm">
        <span class="mu">${esc(msg.username)}</span>
        <span class="mt">${tStr}</span>
        ${msg.intercepted ? '<span class="ibadge">⚠ INTERCEPTED</span>' : ''}
      </div>
      <div class="mb">${esc(msg.content)}</div>
    </div>`;
  feed.appendChild(div);
  feed.scrollTop = feed.scrollHeight;
}

function addSys(text, type) {
  const feed = document.getElementById('feed');
  const div  = document.createElement('div');
  const pfx  = type === 'danger' ? '⚠' : type === 'alert' ? '◈' : '◦';
  div.className = 'sys' + (type === 'alert' ? ' al' : type === 'danger' ? ' dg' : '');
  div.textContent = `${pfx} ${text}`;
  feed.appendChild(div);
  feed.scrollTop = feed.scrollHeight;
}

function esc(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

/* ═══════════════════════════════════════════════════════
   APPLY METRICS FROM WEBSOCKET
═══════════════════════════════════════════════════════ */
function applyMetrics(d) {
  // Topbar
  el('rps').textContent  = Number(d.rps).toLocaleString();
  el('load').textContent = d.server_load + '%';

  // Server panel
  el('cpu-v').textContent = d.server_load + '%';
  setBar('cpu-bar', d.server_load,
    d.server_load >= 80 ? 'var(--red)' : d.server_load >= 50 ? 'var(--amber)' : 'var(--cyan)');

  el('ddos-v').textContent = d.under_attack ? 'ACTIVE' : 'CLEAR';
  el('ddos-v').className   = 'sb-v' + (d.under_attack ? ' r' : '');
  el('atk-v').textContent  = d.attack_attempts;

  if (d.under_attack) {
    el('sdot').className = 'dot r';
    el('stxt').textContent = 'UNDER ATTACK';
    el('stxt').style.color = 'var(--red)';
    document.getElementById('main').classList.add('atk');
    setTimeout(() => document.getElementById('main').classList.remove('atk'), 600);
    if (Math.random() < 0.25) addSys(`DDoS spike — ${Number(d.rps).toLocaleString()} req/s`, 'alert');
  } else {
    el('sdot').className = 'dot';
    el('stxt').textContent = 'PROTECTED';
    el('stxt').style.color = 'var(--green)';
  }

  // Sniffer stats
  el('s-total').textContent = d.total_messages;
  el('s-icp').textContent   = d.intercepted_messages;
  el('s-exp').textContent   = d.exposure_pct + '%';
  el('s-pkt').textContent   = d.packets_per_sec;

  // Score
  const sc = d.security_score;
  el('score-v').textContent = sc + '%';
  setBar('score-bar', sc,
    sc >= 80 ? 'var(--green)' : sc >= 60 ? 'var(--amber)' : 'var(--red)');

  // Metrics bar
  blkCount += Math.floor(Math.random() * 3);
  el('m-pps').textContent = d.packets_per_sec;
  el('m-blk').textContent = blkCount;
  el('m-lat').textContent = d.latency + 'ms';

  // Online
  if (d.online_users) el('sb-online').textContent = d.online_users;

  // Geo
  if (d.geo) updateGeo(d.geo);
}

function setBar(id, pct, color) {
  const b = document.getElementById(id);
  b.style.width      = Math.min(100, Math.max(0, pct)) + '%';
  b.style.background = color;
}

function updateGeo(g) {
  el('geo-flag').textContent  = g.flag;
  el('geo-city').textContent  = g.city + ', ' + g.country;
  el('geo-coord').textContent = g.lat + ', ' + g.lon;
}

function showThreat(msg) {
  const t = document.getElementById('threat');
  t.textContent = '⚠ ' + msg;
  t.classList.add('vis');
  setTimeout(() => t.classList.remove('vis'), 3000);
}

function setSniff(active) {
  const b = document.getElementById('sniff-badge');
  const t = document.getElementById('sniff-txt');
  b.className   = 'sniff' + (active ? '' : ' idle');
  t.textContent = active ? 'SCANNING' : 'IDLE';
  el('m-sniff').textContent = active ? 'ACTIVE' : 'SCANNING';
  el('m-sniff').className   = 'mv ' + (active ? 'r' : 'a');
}

function snifferPulse() {
  if (!appActive) return;
  sniffActive = !sniffActive;
  setSniff(sniffActive);
}

function setTokStat(compromised) {
  const s = document.getElementById('tok-stat');
  s.textContent = compromised ? '● COMPROMISED' : '● SECURE';
  s.className   = 'tok-stat ' + (compromised ? 'comp' : 'safe');
}

/* ═══════════════════════════════════════════════════════
   SESSION SECURITY CHECKS  (REST poll, not WS)
═══════════════════════════════════════════════════════ */
function startSessionChecks() {
  function schedule() {
    sessionCheckTimer = setTimeout(async () => {
      if (!appActive) return;
      try {
        const r = await fetch(`/api/session/${sessionId}/check`);
        const d = await r.json();
        if (d.ok && d.compromised) {
          setTokStat(true);
          el('tok-disp').textContent = d.masked_token;
          sessionId = d.session_id;
          showThreat('SESSION HIJACK ATTEMPT');
          addSys('Session attack — token rotated automatically', 'danger');
          setTimeout(() => setTokStat(false), 4500);
        }
      } catch(e) {}
      schedule();
    }, 12000 + Math.random() * 10000);
  }
  schedule();
}

/* ═══════════════════════════════════════════════════════
   UTILS
═══════════════════════════════════════════════════════ */
function el(id) { return document.getElementById(id); }

function updateClock() {
  const n = new Date();
  el('clk').textContent = [n.getHours(),n.getMinutes(),n.getSeconds()]
    .map(v=>String(v).padStart(2,'0')).join(':');
}
</script>
</body>
</html>
